# Copy this to .env.local and fill in your values

# Local development
VITE_NAKAMA_HOST=localhost
VITE_NAKAMA_PORT=7350
VITE_NAKAMA_SSL=false
VITE_SERVER_KEY=defaultkey

# Production (uncomment and set)
# VITE_NAKAMA_HOST=your-server-ip-or-domain.com
# VITE_NAKAMA_PORT=7350
# VITE_NAKAMA_SSL=true
# VITE_SERVER_KEY=your-production-server-key
